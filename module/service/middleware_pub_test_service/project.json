{
  "name": "module-middleware_pub_test_service",
  "root": "module/service/middleware_pub_test_service",
  "projectType": "application",
  "tags": [
    "scope:module",
    "type:robot-behavior",
    "framework:ros2",
    "framework:go",
    "ros2:humble",
    "language:go",
    "platform:runtime"
  ],
  "implicitDependencies": [
    "infra-runtime",
    "infra-communication",
    "infra-protocol",
    "infra-otel",
    "infra-log",
    "infra-metric",
    "infra-trace",
    "pkg-idl"
  ],
  "targets": {
    "check": {
      "command": "node bin/check-project.mjs module-middleware_pub_test_service"
    },
    "build": {
      "command": "ROS_DISTRO=humble INSTALL_GOLANG=1 scripts/ros2-docker.sh build --packages-select middleware_pub_test --build-base build/middleware_pub_test --install-base install/middleware_pub_test --log-base log/middleware_pub_test",
      "cache": false,
      "inputs": [
        "production",
        "^production",
        "workspace",
        {
          "env": "ROS_DISTRO"
        },
        {
          "env": "INSTALL_GOLANG"
        }
      ],
      "outputs": [
        "{workspaceRoot}/build/middleware_pub_test",
        "{workspaceRoot}/install/middleware_pub_test",
        "{workspaceRoot}/log"
      ]
    },
    "test": {
      "command": "GOCACHE=$(pwd)/.cache/go-build go -C module/service/middleware_pub_test_service test ./...",
      "outputs": []
    }
  },
  "ros2": {
    "package": "middleware_pub_test",
    "distro": "humble",
    "includeInAll": false,
    "env": {
      "INSTALL_GOLANG": "1"
    }
  }
}
